# Application Configuration
APP_NAME="NCCR Rehabilitation Analytics Platform"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=True

# Server Configuration
HOST="0.0.0.0"
PORT=8000

# Database Configuration
DATABASE_URL="sqlite:///./nccr_rehabilitation.db"
# For PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/nccr_db"

# Security
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Data Paths
DATA_IMPORT_PATH="./data/import"
PDF_STORAGE_PATH="./data/pdfs"
EXCEL_STORAGE_PATH="./data/excel"
EXPORT_PATH="./data/exports"

# AI/ML Configuration
MODEL_PATH="./models"
ENABLE_GPU=False
BATCH_SIZE=32

# Logging
LOG_LEVEL="INFO"
LOG_FILE="./logs/app.log"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# EMG Processing
EMG_SAMPLING_RATE=2000
EMG_FILTER_LOWCUT=20
EMG_FILTER_HIGHCUT=450

# Balance Test Thresholds
BALANCE_STABILITY_THRESHOLD=3.0
BALANCE_TIME_THRESHOLD=30

# Clinical Test Standards
GMFCS_LEVELS=5
MIN_6MWT_DISTANCE=0
MAX_6MWT_DISTANCE=1000
